variable "cloud_provider" {
  type = string
}

variable "name" {
  type = string
}

variable "container_image" {
  type = string
}

variable "container_command" {
  type = list(string)
}

variable "environment_variables" {
  type = map(string)
}

variable "schedule_expression" {
  type    = string
  default = null
}

variable "schedule_timezone" {
  type = string
}

variable "tags" {
  type = map(string)
}

variable "aws_region" {
  type    = string
  default = "eu-central-1"
}

variable "aws_config" {
  type    = any
  default = {}
}

variable "gcp_config" {
  type    = any
  default = {}
}

variable "azure_config" {
  type    = any
  default = {}
}

variable "scheduler_input" {
  type    = any
  default = {}
}

variable "enable_command_override_from_scheduler_input" {
  type    = bool
  default = false
}
